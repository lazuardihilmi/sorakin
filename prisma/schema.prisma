datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id             Int          @id @default(autoincrement())
  email          String       @unique
  password       String       // Hashed password
  name           String
  username       String?      @unique // Personal username (nullable if not chosen)
  phone          String?
  isVerified     Boolean      @default(false) // Verified personal badge
  createdAt      DateTime     @default(now())
  creator        Creator?
  donationsSent  Donation[]
}

model Creator {
  id             Int              @id @default(autoincrement())
  userId         Int              @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  username       String           @unique // Custom page URL
  category       String           // Musician, Gamer, etc.
  description    String           // Max 300 chars
  avatarUrl      String?
  coverUrl       String?
  balance        Float            @default(0.0) // Settled cashoutable balance
  pendingBalance Float            @default(0.0) // Held balance awaiting settle
  createdAt      DateTime         @default(now())
  settings       CreatorSettings?
  donations      Donation[]
  settlements    Settlement[]
  withdrawals    Withdrawal[]
  overlay        OverlaySettings?
  milestoneGoal  MilestoneGoal?
  subathonTimer  SubathonTimer?
  votingPoll     VotingPoll?
  mediashareQueue     MediashareQueue[]
  soundboardSounds    SoundboardSound[]
  mediashareSettings  MediashareSettings?
}

model CreatorSettings {
  id                 Int      @id @default(autoincrement())
  creatorId          Int      @unique
  creator            Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  showFeed           Boolean  @default(false)
  showAmount         Boolean  @default(false)
  feeCoverage        String   @default("CREATOR") // "CREATOR" or "SUPPORTER"
  quickAmounts       String   @default("10000,20000,50000,100000") // Comma-separated default values
  socialInstagram    String?
  socialFacebook     String?
  socialX            String?
  socialTiktok       String?
  socialTwitch       String?
  socialYoutube      String?
  socialWebsite      String?
  enableKeywordFilter Boolean @default(false)
  customKeywords     String?  // Comma-separated list
  blockRecentMedia   Boolean  @default(false)
  discordWebhook     String?
  discordTemplate    String?  // e.g. "{sender} tipped {amount}!"
  customWebhookUrl   String?
  customWebhookToken String?
}

model OverlaySettings {
  id              Int      @id @default(autoincrement())
  creatorId       Int      @unique
  creator         Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  key             String   @unique // Unique random URL slug for OBS browser source
  activeThemeId   Int      @default(1)
  alertSoundUrl   String   @default("/sounds/default-alert.mp3")
  alertImageUrl   String   @default("/images/default-alert.gif")
  alertDuration   Int      @default(5) // In seconds
  fontFamily      String   @default("Outfit")
  fontSize        Int      @default(24)
  backgroundColor String   @default("#00000000")
  textColor       String   @default("#ffffff")
  highlightColor  String   @default("#ffc107")
  alertTemplate   String   @default("{sender} baru saja mengirim {amount}!\n\"{message}\"")
}

model Donation {
  id            String      @id // midtrans order_id
  creatorId     Int
  creator       Creator     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  senderId      Int?
  sender        User?       @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderName    String      // Inputted name
  senderEmail   String      // Inputted email
  message       String?
  amount        Float       // Base support amount
  serviceFee    Float       @default(0.0)
  platformFee   Float       @default(0.0)
  vatFee        Float       @default(0.0)
  totalAmount   Float       // Grand total paid
  paymentType   String      // "CREDIT_CARD", "QRIS", "GOPAY"
  paymentStatus String      @default("PENDING") // "PENDING", "SUCCESS", "FAILED"
  isAnonymous   Boolean     @default(false)
  isVAT         Boolean     @default(false)
  createdAt     DateTime    @default(now())
  settledAt     DateTime?
  settlements   Settlement[]
  votingOptionId    Int?
  mediashareVidId   String? // YouTube ID
  mediashareTitle   String?
  soundboardSoundId Int?
}

model Settlement {
  id             Int      @id @default(autoincrement())
  donationId     String
  donation       Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  creatorId      Int
  creator        Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  amount         Float    // Net creator gain
  settleSchedule DateTime // Transaction success + 24 hours (or 3 days for Credit Card)
  status         String   @default("UNSETTLED") // "UNSETTLED" or "SETTLED"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Withdrawal {
  id            Int      @id @default(autoincrement())
  creatorId     Int
  creator       Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  amount        Float
  bankName      String
  accountNumber String
  accountName   String
  status        String   @default("PENDING") // "PENDING", "SUCCESS", "FAILED"
  createdAt     DateTime @default(now())
}

model MilestoneGoal {
  id            Int      @id @default(autoincrement())
  creatorId     Int      @unique
  creator       Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title         String
  targetAmount  Float
  currentAmount Float    @default(0.0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SubathonTimer {
  id                 Int      @id @default(autoincrement())
  creatorId          Int      @unique
  creator            Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  remainingSeconds   Int      @default(3600)
  isActive           Boolean  @default(false)
  secondsPerRupiah   Float    @default(0.01)
  maxSeconds         Int      @default(86400)
  lastUpdatedAt      DateTime @default(now())
  createdAt          DateTime @default(now())
}

model VotingPoll {
  id        Int            @id @default(autoincrement())
  creatorId Int            @unique
  creator   Creator        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title     String
  isActive  Boolean        @default(true)
  options   VotingOption[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model VotingOption {
  id         Int        @id @default(autoincrement())
  pollId     Int
  poll       VotingPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  name       String
  votesCount Float      @default(0.0)
  createdAt  DateTime   @default(now())
}

model MediashareQueue {
  id         Int      @id @default(autoincrement())
  creatorId  Int
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  youtubeId  String   // Video ID (for YouTube) or empty string for other types
  mediaUrl   String   @default("") // Original URL pasted by supporter
  mediaType  String   @default("youtube") // "youtube" | "tiktok" | "ig_reels" | "voice_note"
  title      String
  senderName String
  duration   Int
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}

model SoundboardSound {
  id        Int      @id @default(autoincrement())
  creatorId Int
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  name      String
  soundUrl  String
  price     Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MediashareSettings {
  id                  Int      @id @default(autoincrement())
  creatorId           Int      @unique
  creator             Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  isActive            Boolean  @default(true)
  enableYoutube       Boolean  @default(true)
  enableTiktok        Boolean  @default(false)
  enableIgReels       Boolean  @default(false)
  enableVoiceNote     Boolean  @default(false)
  maxVideoDuration    Int      @default(300)
  pricePerSecond      Int      @default(100)
  minVideoPrice       Int      @default(10000)
  maxAudioDuration    Int      @default(60)
  audioPricePerSecond Int      @default(200)
  minAudioPrice       Int      @default(50000)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
